<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>

    <Version>1.1.2</Version>
    <Company>Alexander Suvorov</Company>
    <Product>Smart Password Manager Desktop</Product>
    <Copyright>BSD 3-Clause License</Copyright>
    <Description>Smart Password Manager Desktop (C#)</Description>
    <RepositoryUrl>https://github.com/smartlegionlab/SmartPasswordManagerCsharpDesktop</RepositoryUrl>

    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="app.ico" />
    <EmbeddedResource Include="app.ico" />
  </ItemGroup>

</Project>